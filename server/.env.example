# Copy to .env and fill in. .env is gitignored — never commit real values.

# Neon connection string. Use the POOLED one (its host contains "-pooler").
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Signing key for sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=

# Where this API is reachable. Locally that's the Express port.
BETTER_AUTH_URL=http://localhost:3001

# Where the Vite dev server / deployed frontend lives (CORS + cookie trust).
CLIENT_URL=http://localhost:5173

PORT=3001
